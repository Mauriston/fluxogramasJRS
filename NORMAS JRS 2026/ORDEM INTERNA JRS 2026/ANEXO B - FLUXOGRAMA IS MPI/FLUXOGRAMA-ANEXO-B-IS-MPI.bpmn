    <bpmn:sequenceFlow id="Flow_05" sourceRef="Task_LancamentoResultados" targetRef="Task_ConvocacaoInspecionado" />
    <bpmn:sequenceFlow id="Flow_06" sourceRef="Task_ConvocacaoInspecionado" targetRef="Task_EntrevistaExameClinico" />
    <bpmn:sequenceFlow id="Flow_07" sourceRef="Task_EntrevistaExameClinico" targetRef="Gateway_CompetenteParaConcluir" />
    <bpmn:sequenceFlow id="Flow_08_Sim" name="Sim" sourceRef="Gateway_CompetenteParaConcluir" targetRef="Task_ConclusaoAssinatura" />
    <bpmn:sequenceFlow id="Flow_09_Nao" name="Não" sourceRef="Gateway_CompetenteParaConcluir" targetRef="EndEvent_DeclinioCompetencia" />
    <bpmn:sequenceFlow id="Flow_10" sourceRef="Task_ConclusaoAssinatura" targetRef="Task_MinutaMSGConclusao" />
