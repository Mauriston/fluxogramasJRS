        <bpmn:flowNodeRef>Task_ConferenciaDadosAutorizacaoTransmissao</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_TransmissaoMSG</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_MedicoPeritoIsoladoQualificado" name="Médico Perito Isolado Qualificado">
