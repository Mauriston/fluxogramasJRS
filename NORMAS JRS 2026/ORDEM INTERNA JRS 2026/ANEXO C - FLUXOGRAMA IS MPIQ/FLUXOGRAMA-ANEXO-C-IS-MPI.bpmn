    <bpmn:laneSet id="LaneSet_InspecaoSaude">
      <bpmn:lane id="Lane_ISAECMM" name="JASE / CPMM">
        <bpmn:flowNodeRef>EndEvent_DeclinioCompetencia</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_ISAECentroS" name="JSAE / ComForS">
        <bpmn:flowNodeRef>Task_ApreciacaoDocumental</bpmn:flowNodeRef>
      </bpmn:lane>
