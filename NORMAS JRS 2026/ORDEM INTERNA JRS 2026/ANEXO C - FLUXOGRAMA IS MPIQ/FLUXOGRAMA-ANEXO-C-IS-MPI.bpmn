        <bpmn:flowNodeRef>Gateway_HaIncapacidade</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_IncapacidadeTemporariaDefinitiva</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ConclusaoISAssinaturaEletronica</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_ExamesComplementares" name="Serviços de Apoio">
        <bpmn:flowNodeRef>Task_RealizacaoExamesComplementares</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RealizacaoNovosExamesRespostaParecer</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Secretaria" name="Secretaria">
        <bpmn:flowNodeRef>StartEvent_Recebimento</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AberturaIS</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_EntregaSolicitacaoExames</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_LancamentoResultadosExames</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ConvocacaoInspecionado</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_LancamentoNovosResultados</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ConfeccaoMinutaMSG</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:task id="Task_RealizacaoExamesComplementares" name="Realização dos exames complementares">
      <bpmn:incoming>Flow_03</bpmn:incoming>
      <bpmn:outgoing>Flow_04</bpmn:outgoing>
    </bpmn:task>
